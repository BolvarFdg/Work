+            if isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+        ]
+        non_uniform_groups = [
+            g for g in kv_cache_groups
+            if not isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+        ]
