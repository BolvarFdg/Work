+# ---------------------------------------------------------------------------
+# Patch get_kv_cache_groups to pull out HiddenStateCacheSpec layers BEFORE
+# the DeepSeek-V4 grouping path (group_and_unify_kv_cache_specs). Without
+# this, HiddenStateCacheSpec (a subclass of MLAAttentionSpec) gets mixed
+# into the MLA group, causing block_size mismatches and assertion failures.
+# ---------------------------------------------------------------------------
+
+_orig_get_kv_cache_groups = vllm.v1.core.kv_cache_utils.get_kv_cache_groups
+
+
+def _ascend_get_kv_cache_groups(
+    vllm_config: VllmConfig,
+    kv_cache_spec: dict[str, KVCacheSpec],
+) -> list[KVCacheGroupSpec]:
+    # Pull HiddenStateCacheSpec layers out before any grouping logic.
+    hidden_specs = {
+        k: v for k, v in kv_cache_spec.items() if isinstance(v, HiddenStateCacheSpec)
+    }
+    filtered_spec = {
+        k: v for k, v in kv_cache_spec.items() if not isinstance(v, HiddenStateCacheSpec)
+    }
+
+    groups = _orig_get_kv_cache_groups(vllm_config, filtered_spec)
+
+    # Add hidden-state layers back as standalone groups. Unlike the upstream
+    # pull-out code which tries to align to a "common page" (broken for
+    # DeepSeek-V4 where each UniformTypeKVCacheSpecs group has a different
+    # page_size_bytes sum), we keep the HiddenStateCacheSpec's own page size
+    # and let _ascend_get_kv_cache_config_deepseek_v4 allocate a separate
+    # cache tensor for it (same pattern as MTP layers).
+    for name, spec in hidden_specs.items():
+        groups.append(KVCacheGroupSpec([name], spec))
+
+    return groups
+
+
+# ---------------------------------------------------------------------------
+# Patch _pool_bytes_per_block to handle the mixed case where DeepSeek-V4
+# UniformTypeKVCacheSpecs groups coexist with HiddenStateCacheSpec groups
+# (extract_hidden_states spec-decode method). Without this, the general-case
+# branch calls get_uniform_page_size which asserts all page sizes are equal,
+# but UniformTypeKVCacheSpecs groups have different sums and the
+# HiddenStateCacheSpec has its own page size.
+# ---------------------------------------------------------------------------
+
+_orig_pool_bytes_per_block = vllm.v1.core.kv_cache_utils._pool_bytes_per_block
+
+
+def _ascend_pool_bytes_per_block(kv_cache_groups: list[KVCacheGroupSpec]) -> int:
+    uniform_groups = [
+        g for g in kv_cache_groups
+        if isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+    ]
+    non_uniform_groups = [
+        g for g in kv_cache_groups
+        if not isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+    ]
+
+    if not non_uniform_groups:
+        return _orig_pool_bytes_per_block(kv_cache_groups)
+
+    bytes_per_block = 0
+    if uniform_groups:
+        # DeepSeek-V4 part: sum of page sizes * max layer tuples.
+        full_mla_spec = cast(
+            UniformTypeKVCacheSpecs, uniform_groups[0].kv_cache_spec
+        )
+        layer_tuple_page_bytes = sum(full_mla_spec.get_page_sizes())
+        num_layer_tuples = max(
+            cast(UniformTypeKVCacheSpecs, g.kv_cache_spec).get_num_layer_tuples()
+            for g in uniform_groups
+        )
+        bytes_per_block += layer_tuple_page_bytes * num_layer_tuples
+
+    # Add each non-uniform group's page size (HiddenStateCacheSpec, etc.).
+    for g in non_uniform_groups:
+        bytes_per_block += g.kv_cache_spec.page_size_bytes
+
+    return bytes_per_block
+
+
+# ---------------------------------------------------------------------------
+# Patch get_kv_cache_config_from_groups to route the mixed case
+# (UniformTypeKVCacheSpecs + HiddenStateCacheSpec) to the DeepSeek-V4
+# allocator instead of the general-case path which would crash.
+# ---------------------------------------------------------------------------
+
+_orig_get_kv_cache_config_from_groups = (
+    vllm.v1.core.kv_cache_utils.get_kv_cache_config_from_groups
+)
+
+
+def _ascend_get_kv_cache_config_from_groups(
+    vllm_config: VllmConfig,
+    kv_cache_groups: list[KVCacheGroupSpec],
+    available_memory: int,
+) -> "KVCacheConfig":
+    has_uniform = any(
+        isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs) for g in kv_cache_groups
+    )
+    has_non_uniform = any(
+        not isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs) for g in kv_cache_groups
+    )
+
+    if has_uniform and has_non_uniform:
+        # Mixed case: DeepSeek-V4 + HiddenStateCacheSpec.
+        # All tensors MUST share the same num_blocks so that downstream
+        # shrink-to-min-blocks (tensor.size % num_blocks == 0) passes.
+        uniform_groups = [
+            g for g in kv_cache_groups
+            if isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+        ]
+        non_uniform_groups = [
+            g for g in kv_cache_groups
+            if not isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+        ]
+
+        # Compute global num_blocks from total bytes_per_block.
+        bytes_per_block = _ascend_pool_bytes_per_block(kv_cache_groups)
+        num_blocks = available_memory // bytes_per_block
+        num_blocks = may_override_num_blocks(vllm_config, num_blocks)
+
+        # Pass a fake available_memory to the DeepSeek-V4 allocator so it
+        # produces the SAME num_blocks for the uniform tensors.
+        # uniform_bytes_per_block = layer_tuple_page_bytes * num_layer_tuples
+        # So: fake_memory = num_blocks * uniform_bytes_per_block
+        #     num_blocks_internal = fake_memory // uniform_bytes_per_block = num_blocks
+        uniform_bytes_per_block = _ascend_pool_bytes_per_block(uniform_groups)
+        fake_memory = num_blocks * uniform_bytes_per_block
+        num_blocks_u, kv_cache_tensors = _get_kv_cache_config_deepseek_v4(
+            vllm_config, uniform_groups, fake_memory
+        )
+
+        # Use num_blocks_u (from the allocator) for non-uniform tensors too,
+        # so every tensor.size is divisible by the same num_blocks value.
+        for g in non_uniform_groups:
+            ps = g.kv_cache_spec.page_size_bytes
+            for name in g.layer_names:
+                kv_cache_tensors.append(
+                    KVCacheTensor(size=ps * num_blocks_u, shared_by=[name])
+                )
+
+        return KVCacheConfig(
+            num_blocks=num_blocks_u,
+            kv_cache_tensors=kv_cache_tensors,
+            kv_cache_groups=kv_cache_groups,
+        )
+
+    return _orig_get_kv_cache_config_from_groups(
+        vllm_config, kv_cache_groups, available_memory
+    )
+
+
+# ---------------------------------------------------------------------------
+# Patch _max_memory_usage_bytes_from_groups to handle the mixed case
+# (UniformTypeKVCacheSpecs + HiddenStateCacheSpec). Without this, the general
+# case calls get_uniform_page_size which asserts all page sizes are equal.
+# This function is called by _check_enough_kv_cache_memory during startup.
+# ---------------------------------------------------------------------------
+
+_orig_max_memory_usage_bytes_from_groups = (
+    vllm.v1.core.kv_cache_utils._max_memory_usage_bytes_from_groups
+)
+
+
+def _ascend_max_memory_usage_bytes_from_groups(
+    vllm_config: VllmConfig,
+    kv_cache_groups: list[KVCacheGroupSpec],
+) -> int:
+    if not kv_cache_groups:
+        return 0
+
+    uniform_groups = [
+        g for g in kv_cache_groups
+        if isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+    ]
+    non_uniform_groups = [
+        g for g in kv_cache_groups
+        if not isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+    ]
+
+    if not non_uniform_groups:
+        # Pure uniform case — delegate to original.
+        return _orig_max_memory_usage_bytes_from_groups(
+            vllm_config, kv_cache_groups
+        )
+
+    total = 0
+
+    # Uniform part: use the DeepSeek-V4 layer-tuple calculation.
+    if uniform_groups:
+        full_mla_spec = cast(
+            UniformTypeKVCacheSpecs, uniform_groups[0].kv_cache_spec
+        )
+        layer_tuple_bytes = sum(full_mla_spec.get_page_sizes())
+        num_layer_tuples = max(
+            cast(UniformTypeKVCacheSpecs, g.kv_cache_spec).get_num_layer_tuples()
+            for g in uniform_groups
+        )
+        for group in uniform_groups:
+            group_spec = cast(UniformTypeKVCacheSpecs, group.kv_cache_spec)
+            g_max_mem_usage_pages = group_spec.max_memory_usage_pages(
+                vllm_config
+            )
+            total += (
+                num_layer_tuples * g_max_mem_usage_pages * layer_tuple_bytes
+            )
+
+    # Non-uniform part: each group computes its own max memory usage.
+    for group in non_uniform_groups:
+        total += group.kv_cache_spec.max_memory_usage_bytes(vllm_config)
+
+    return total
+
+
 vllm.v1.core.kv_cache_utils.resolve_kv_cache_block_sizes = _ascend_resolve_kv_cache_block_sizes
 vllm.v1.core.kv_cache_utils.group_and_unify_kv_cache_specs = group_and_unify_kv_cache_specs
+vllm.v1.core.kv_cache_utils.get_kv_cache_groups = _ascend_get_kv_cache_groups
+vllm.v1.core.kv_cache_utils._pool_bytes_per_block = _ascend_pool_bytes_per_block
+vllm.v1.core.kv_cache_utils.get_kv_cache_config_from_groups = _ascend_get_kv_cache_config_from_groups
+vllm.v1.core.kv_cache_utils._max_memory_usage_bytes_from_groups = _ascend_max_memory_usage_bytes_from_groups
 vllm.v1.core.kv_cache_utils._get_kv_cache_config_deepseek_v4 = _get_kv_cache_config_deepseek_v4
 vllm.v1.core.kv_cache_utils._get_kv_cache_groups_uniform_groups = _get_kv_cache_groups_uniform_groups
 
