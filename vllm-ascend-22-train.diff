+def _ascend_get_kv_cache_groups(
+    vllm_config: VllmConfig,
+    kv_cache_spec: dict[str, KVCacheSpec],
+) -> list[KVCacheGroupSpec]:
+    # Pull HiddenStateCacheSpec layers out before any grouping logic.
+    hidden_specs = {
+        k: v for k, v in kv_cache_spec.items() if isinstance(v, HiddenStateCacheSpec)
+    }
+    filtered_spec = {
+        k: v for k, v in kv_cache_spec.items() if not isinstance(v, HiddenStateCacheSpec)
+    }
+
+    groups = _orig_get_kv_cache_groups(vllm_config, filtered_spec)
+
+    # Add hidden-state layers back as standalone groups. Unlike the upstream
+    # pull-out code which tries to align to a "common page" (broken for
+    # DeepSeek-V4 where each UniformTypeKVCacheSpecs group has a different
+    # page_size_bytes sum), we keep the HiddenStateCacheSpec's own page size
+    # and let _ascend_get_kv_cache_config_deepseek_v4 allocate a separate
+    # cache tensor for it (same pattern as MTP layers).
+    for name, spec in hidden_specs.items():
+        groups.append(KVCacheGroupSpec([name], spec))
+
+    return groups
