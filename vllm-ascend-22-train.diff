+# This function is called by _check_enough_kv_cache_memory during startup.
+# ---------------------------------------------------------------------------
+
+_orig_max_memory_usage_bytes_from_groups = (
+    vllm.v1.core.kv_cache_utils._max_memory_usage_bytes_from_groups
+)
+
+
+def _ascend_max_memory_usage_bytes_from_groups(
+    vllm_config: VllmConfig,
+    kv_cache_groups: list[KVCacheGroupSpec],
+) -> int:
+    if not kv_cache_groups:
+        return 0
+
+    uniform_groups = [
+        g for g in kv_cache_groups
+        if isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+    ]
+    non_uniform_groups = [
+        g for g in kv_cache_groups
+        if not isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+    ]
+
+    if not non_uniform_groups:
+        # Pure uniform case — delegate to original.
+        return _orig_max_memory_usage_bytes_from_groups(
+            vllm_config, kv_cache_groups
+        )
+
+    total = 0
+
+    # Uniform part: use the DeepSeek-V4 layer-tuple calculation.
+    if uniform_groups:
+        full_mla_spec = cast(
+            UniformTypeKVCacheSpecs, uniform_groups[0].kv_cache_spec
+        )
+        layer_tuple_bytes = sum(full_mla_spec.get_page_sizes())
+        num_layer_tuples = max(
+            cast(UniformTypeKVCacheSpecs, g.kv_cache_spec).get_num_layer_tuples()
+            for g in uniform_groups
+        )
+        for group in uniform_groups:
+            group_spec = cast(UniformTypeKVCacheSpecs, group.kv_cache_spec)
+            g_max_mem_usage_pages = group_spec.max_memory_usage_pages(
+                vllm_config
+            )
+            total += (
+                num_layer_tuples * g_max_mem_usage_pages * layer_tuple_bytes
+            )
+
+    # Non-uniform part: each group computes its own max memory usage.
+    for group in non_uniform_groups:
+        total += group.kv_cache_spec.max_memory_usage_bytes(vllm_config)
+
+    return total
+
+
