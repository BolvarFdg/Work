+# branch calls get_uniform_page_size which asserts all page sizes are equal,
+# but UniformTypeKVCacheSpecs groups have different sums and the
+# HiddenStateCacheSpec has its own page size.
+# ---------------------------------------------------------------------------
+
+_orig_pool_bytes_per_block = vllm.v1.core.kv_cache_utils._pool_bytes_per_block
+
+
+def _ascend_pool_bytes_per_block(kv_cache_groups: list[KVCacheGroupSpec]) -> int:
+    uniform_groups = [
+        g for g in kv_cache_groups
+        if isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+    ]
+    non_uniform_groups = [
+        g for g in kv_cache_groups
+        if not isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs)
+    ]
+
+    if not non_uniform_groups:
+        return _orig_pool_bytes_per_block(kv_cache_groups)
+
+    bytes_per_block = 0
+    if uniform_groups:
