+def _ascend_get_kv_cache_config_from_groups(
+    vllm_config: VllmConfig,
+    kv_cache_groups: list[KVCacheGroupSpec],
+    available_memory: int,
+) -> "KVCacheConfig":
+    has_uniform = any(
+        isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs) for g in kv_cache_groups
+    )
+    has_non_uniform = any(
+        not isinstance(g.kv_cache_spec, UniformTypeKVCacheSpecs) for g in kv_cache_groups
+    )
+
+    if has_uniform and has_non_uniform:
+        # Mixed case: DeepSeek-V4 + HiddenStateCacheSpec.
+        # All tensors MUST share the same num_blocks so that downstream
+        # shrink-to-min-blocks (tensor.size % num_blocks == 0) passes.
