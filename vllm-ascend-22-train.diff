+        full_mla_spec = cast(
+            UniformTypeKVCacheSpecs, uniform_groups[0].kv_cache_spec
+        )
+        layer_tuple_page_bytes = sum(full_mla_spec.get_page_sizes())
+        num_layer_tuples = max(
+            cast(UniformTypeKVCacheSpecs, g.kv_cache_spec).get_num_layer_tuples()
+            for g in uniform_groups
+        )
+        bytes_per_block += layer_tuple_page_bytes * num_layer_tuples
+
+    # Add each non-uniform group's page size (HiddenStateCacheSpec, etc.).
+    for g in non_uniform_groups:
+        bytes_per_block += g.kv_cache_spec.page_size_bytes
+
+    return bytes_per_block
